# ============================================================
# DatabricksTV Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# See README.md for detailed setup instructions.
# ============================================================

# === Required: Databricks Connection ===
DATABRICKS_PROFILE=my-workspace-profile    # CLI profile from `databricks auth login`

# === Required: Unity Catalog ===
CATALOG=my_catalog                         # Your UC catalog name

# === Required: SQL Warehouse ===
WAREHOUSE_ID=your_warehouse_id             # Find in SQL Warehouses UI → ID in URL bar

# === Optional: Override defaults ===
# SCHEMA=databrickstv                                        # Default: databrickstv
# SERVING_ENDPOINT=databricks-claude-sonnet-4-6              # Default: databricks-claude-sonnet-4-6
# MODEL_NAME=databricks-meta-llama-3-3-70b-instruct          # Default: databricks-meta-llama-3-3-70b-instruct
# MLFLOW_EXPERIMENT_NAME=/Shared/databrickstv-agent           # Default: /Shared/databrickstv-agent

# === CI/CD Only (set as GitHub repo secrets, not here) ===
# DATABRICKS_HOST=https://my-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...
